# --- Variables ---
CLANG = clang++-20
OPT = opt-20
LLVM_LINK = llvm-link-20
LLC = llc-20
ARCH = sm_89
CUDA_PATH = /usr/local/cuda

# Include paths
INCLUDES = -I$(CUDA_PATH)/include -I/usr/include/x86_64-linux-gnu

# Build Targets
all: uvm_tracker_bin uvm_tracker_bin_old

# 1. Generate Kernel IR (Device Only)
kernel.ll: ../test_kernel.cu
	$(CLANG) -x cuda $< -include __clang_cuda_runtime_wrapper.h --offload-arch=$(ARCH) --cuda-device-only -emit-llvm -S -o $@

# 2. Compile MarkAccess Library to Bitcode
libMarkAccess.bc: ../libMarkAccess.cu
	$(CLANG) -target nvptx64-nvidia-cuda --cuda-gpu-arch=$(ARCH) --cuda-path=$(CUDA_PATH) -g -O0 \
	-D__x86_64__ --cuda-device-only -emit-llvm -fno-builtin -c $< -o $@

# 3. Instrument the Kernel IR using the Pass
# Note: This assumes UvmTrackingPass.so is already built via CMake
instrumented.bc: kernel.ll UvmTrackingPass.so
	$(OPT) -load-pass-plugin=./UvmTrackingPass.so -passes='uvm-track' $< -o $@

# 4. Link Instrumented Kernel with the Library
final_gpu.bc: instrumented.bc libMarkAccess.bc
	$(LLVM_LINK) $^ -o $@

# 5. Generate PTX from merged Bitcode
final.ptx: final_gpu.bc
	$(LLC) --debug-entry-values --debugger-tune=gdb -march=nvptx64 -mcpu=$(ARCH) $< -o $@
#	$(CLANG) -target nvptx64-nvidia-cuda \
  --cuda-gpu-arch=$(ARCH) \
  -S final_gpu.bc -o final.ptx

# 6. Compile Host Runtime Support
host_runtime.o: ../host_runtime.cu
	$(CLANG) -c $< --cuda-host-only -o $@ $(INCLUDES)

# 7. Final Binary: Link Host Code with Instrumented PTX
#uvm_tracker_bin: ../test_kernel.cu host_runtime.o final.ptx
#	$(CLANG) $< host_runtime.o --cuda-gpu-arch=$(ARCH) --cuda-host-only \
#	-L$(CUDA_PATH)/lib64 -lcudart \
#	-Xoffload-linker -T -Xoffload-linker final.ptx -o $@


# 7. Final Binary: Use -mlink-builtin-bitcode or -Xcuda-ptx
uvm_tracker_bin_old: ../test_kernel.cu host_runtime.o final.ptx
	$(CLANG) ../test_kernel.cu host_runtime.o \
	--cuda-gpu-arch=$(ARCH) \
	-L$(CUDA_PATH)/lib64 -lcudart \
	-Xoffload-linker --pme-id=0 \
	-Xoffload-linker -T -Xoffload-linker final.ptx \
	-o $@


test_kernel_host.o: ../test_kernel.cu
	$(CLANG) \
	--cuda-gpu-arch=$(ARCH) \
	-fcuda-rdc \
	-g -O0 \
	-c $< -o $@ $(INCLUDES)

uvm_tracker_bin: cuda_link_stub.cu test_kernel_host.o host_runtime.o final.ptx
	$(CLANG) cuda_link_stub.cu test_kernel_host.o host_runtime.o \
	--cuda-gpu-arch=$(ARCH) \
	-fcuda-rdc \
	-g -O0 \
	-L$(CUDA_PATH)/lib64 -lcudart \
	-o $@

